# 🎓 LPU Advisor Environment Variables Template
# Copy this file to .env and fill in the actual values.
# DO NOT commit your .env file to version control.

# --- Mandatory for Production (Aiven PostgreSQL) ---
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://avnadmin:your_password@your-host.aivencloud.com:15571/defaultdb?sslmode=require

# --- Puter AI Configuration (Primary AI Engine) ---
# Get your Master Token from https://puter.com/account/api-keys
PUTER_MASTER_TOKEN=your_puter_master_token_here
PUTER_AI_MODEL=gpt-4o-mini
PUTER_API_ENDPOINT=https://api.puter.com/v1

# --- OpenAI Configuration (Automatic Fallback Engine) ---
# Get your API Key from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# --- System Configuration ---
# Force pure Python implementation of protobuf (required for some environments)
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# Streamlit Server Settings
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_SHOWSTDERR=false
STREAMLIT_LOGGER_LEVEL=warning
