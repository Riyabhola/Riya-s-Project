# LPU Advisor Environment Variables
# Copy this file to .env and fill in the values

# Mandatory for Production (Aiven PostgreSQL)
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Protobuf Implementation (Required for some environments)
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# Optional: Puter AI Token (Fallback to Guest Mode if not provided)
PUTER_TOKEN=
